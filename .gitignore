# Terraform runtime data
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Local Terraform input values. Keep only sanitized examples in Git.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Terraform local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Local secrets and machine-specific config
.env
.env.*
!.env.example
*.pem
*.key
id_rsa
id_ed25519
*.pub

# Ansible runtime artifacts
*.retry

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp
*.swo
